# During v0.1-alpha development, the peer-dep on
# @de-otio/crypto-envelope@>=0.2.0-alpha.1 <0.3.0 cannot resolve — that
# version does not exist yet (crypto-envelope is at 0.1.0-alpha.1). Ambient
# type shim in src/types/crypto-envelope.d.ts provides the subset keyring
# needs for typecheck; legacy-peer-deps unblocks `npm install`.
#
# Remove this file (or delete the line) once crypto-envelope v0.2 publishes.
legacy-peer-deps=true
